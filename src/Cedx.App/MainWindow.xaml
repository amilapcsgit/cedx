<Window x:Class="Cedx.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CEDX Asset Manager"
        Width="1420"
        Height="860"
        MinWidth="1120"
        MinHeight="680"
        Background="{StaticResource WindowBackgroundBrush}">
    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Find" Executed="FindCommand_Executed" />
    </Window.CommandBindings>
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
        <KeyBinding Key="F" Modifiers="Control" Command="ApplicationCommands.Find" />
        <KeyBinding Key="E" Modifiers="Control" Command="{Binding ExportCsvCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />
            <RowDefinition Height="*" />
            <RowDefinition Height="26" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="CEDX Asset Manager"
                           VerticalAlignment="Center"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <Button Grid.Column="1"
                        Margin="0,0,8,0"
                        Content="Refresh"
                        Command="{Binding RefreshCommand}" />
                <Button Grid.Column="2"
                        Margin="0,0,8,0"
                        Content="Open Assets Folder"
                        Command="{Binding OpenAssetsFolderCommand}" />
                <Button Grid.Column="3"
                        Content="Export CSV"
                        Command="{Binding ExportCsvCommand}" />
                <TextBlock Grid.Column="5"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}"
                           Text="{Binding LastRefreshText, StringFormat=Last refresh: {0}}" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="420" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock Text="Filters"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12" />

                        <TextBlock Text="Search"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,0,0,4" />
                        <TextBox x:Name="SearchBox"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12" />

                        <TextBlock Text="OS"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding OsOptions}"
                                  SelectedItem="{Binding SelectedOsFilter}"
                                  Margin="0,0,0,12" />

                        <TextBlock Text="Manufacturer"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding ManufacturerOptions}"
                                  SelectedItem="{Binding SelectedManufacturerFilter}"
                                  Margin="0,0,0,12" />

                        <TextBlock Text="Status"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding StatusOptions}"
                                  SelectedItem="{Binding SelectedStatusFilter}"
                                  Margin="0,0,0,12" />

                        <TextBlock Text="Low Storage Threshold GB"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,0,0,4" />
                        <TextBox Text="{Binding LowStorageThresholdGb, UpdateSourceTrigger=LostFocus}"
                                 Margin="0,0,0,12" />

                        <CheckBox Content="Low storage only"
                                  IsChecked="{Binding LowStorageOnly}" />
                        <CheckBox Content="Has AnyDesk ID"
                                  IsChecked="{Binding HasAnyDeskOnly}" />
                        <CheckBox Content="Has BitLocker Off"
                                  IsChecked="{Binding HasBitLockerOffOnly}" />
                        <CheckBox Content="Has stored credentials"
                                  IsChecked="{Binding HasStoredCredentialsOnly}" />

                        <TextBlock Text="Asset Folder"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,24,0,4" />
                        <TextBox Text="{Binding AssetsFolderPath, UpdateSourceTrigger=LostFocus}" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <DataGrid Grid.Column="1"
                      ItemsSource="{Binding AssetsView}"
                      SelectedItem="{Binding SelectedAsset, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      FrozenColumnCount="2">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Status" Binding="{Binding OnlineStatus}" Width="78" />
                    <DataGridTextColumn Header="Hostname" Binding="{Binding Hostname}" Width="160" />
                    <DataGridTextColumn Header="IP Address" Binding="{Binding IpAddress}" Width="118" />
                    <DataGridTextColumn Header="User" Binding="{Binding WindowsAccount}" Width="180" />
                    <DataGridTextColumn Header="OS" Binding="{Binding OsVersion}" Width="230" />
                    <DataGridTextColumn Header="Manufacturer" Binding="{Binding Manufacturer}" Width="120" />
                    <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="160" />
                    <DataGridTextColumn Header="RAM" Binding="{Binding RamDisplay}" Width="78" />
                    <DataGridTextColumn Header="C: Free" Binding="{Binding CDriveFreeDisplay}" Width="88" />
                    <DataGridTextColumn Header="AnyDesk" Binding="{Binding AnyDeskDisplay}" Width="112" />
                    <DataGridTextColumn Header="Last Reboot / Uptime" Binding="{Binding LastRebootOrUptime}" Width="220" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1,0,0,0">
                <Grid>
                    <TextBlock Text="Select an asset to view details."
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource MutedTextBrush}">
                        <TextBlock.Style>
                            <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedAsset}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ScrollViewer.Style>
                            <Style TargetType="{x:Type ScrollViewer}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedAsset}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>

                        <StackPanel Margin="18">
                            <TextBlock Text="{Binding SelectedAsset.Hostname}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4" />
                            <TextBlock Text="{Binding SelectedAsset.SourceFileName}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Margin="0,0,0,16" />

                            <TextBlock Text="Identity" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="112" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="28" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Foreground="{StaticResource MutedTextBrush}" Text="Hostname" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedAsset.Hostname}" />
                                <Button Grid.Row="0" Grid.Column="2" Content="Copy" Command="{Binding CopyTextCommand}" CommandParameter="{Binding SelectedAsset.Hostname}" />
                                <TextBlock Grid.Row="1" Foreground="{StaticResource MutedTextBrush}" Text="IP" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedAsset.IpAddress}" />
                                <Button Grid.Row="1" Grid.Column="2" Content="Copy" Command="{Binding CopyTextCommand}" CommandParameter="{Binding SelectedAsset.IpAddress}" />
                                <TextBlock Grid.Row="2" Foreground="{StaticResource MutedTextBrush}" Text="User" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedAsset.WindowsAccount}" />
                                <Button Grid.Row="2" Grid.Column="2" Content="Copy" Command="{Binding CopyTextCommand}" CommandParameter="{Binding SelectedAsset.WindowsAccount}" />
                                <TextBlock Grid.Row="3" Foreground="{StaticResource MutedTextBrush}" Text="Domain" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedAsset.PcDomain}" />
                            </Grid>

                            <TextBlock Text="Hardware" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="112" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Foreground="{StaticResource MutedTextBrush}" Text="Maker" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedAsset.Manufacturer}" />
                                <TextBlock Grid.Row="1" Foreground="{StaticResource MutedTextBrush}" Text="Model" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedAsset.Model}" />
                                <TextBlock Grid.Row="2" Foreground="{StaticResource MutedTextBrush}" Text="Serial" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedAsset.SerialNumber}" />
                                <TextBlock Grid.Row="3" Foreground="{StaticResource MutedTextBrush}" Text="RAM" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedAsset.RamDisplay}" />
                                <TextBlock Grid.Row="4" Foreground="{StaticResource MutedTextBrush}" Text="CPU" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedAsset.Cpu}" TextWrapping="Wrap" />
                            </Grid>

                            <TextBlock Text="OS" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="112" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="28" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Foreground="{StaticResource MutedTextBrush}" Text="Version" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedAsset.Os.Version}" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="1" Foreground="{StaticResource MutedTextBrush}" Text="Install" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedAsset.Os.InstallDate}" />
                                <TextBlock Grid.Row="2" Foreground="{StaticResource MutedTextBrush}" Text="Reboot" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedAsset.Os.LastRebootTime}" />
                                <TextBlock Grid.Row="3" Foreground="{StaticResource MutedTextBrush}" Text="Uptime" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedAsset.Os.SystemUptime}" />
                            </Grid>

                            <TextBlock Text="Network" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="112" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="28" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Foreground="{StaticResource MutedTextBrush}" Text="Mode" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedAsset.Network.NetworkMode}" />
                                <TextBlock Grid.Row="1" Foreground="{StaticResource MutedTextBrush}" Text="Gateway" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedAsset.Network.DefaultGateway}" />
                                <TextBlock Grid.Row="2" Foreground="{StaticResource MutedTextBrush}" Text="DNS" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedAsset.Network.DnsServers}" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="3" Foreground="{StaticResource MutedTextBrush}" Text="AnyDesk" />
                                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Text="{Binding SelectedAsset.AnyDeskId}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <Button Content="Copy" Command="{Binding CopyTextCommand}" CommandParameter="{Binding SelectedAsset.AnyDeskId}" Margin="0,0,6,0" />
                                    <Button Content="Launch" Command="{Binding LaunchAnyDeskCommand}" CommandParameter="{Binding SelectedAsset.AnyDeskId}" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Security" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding SelectedAsset.Antivirus, StringFormat=Antivirus: {0}}" TextWrapping="Wrap" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding SelectedAsset.Os.Activation, StringFormat=OS Activation: {0}}" TextWrapping="Wrap" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding SelectedAsset.StoredCredentials.Count, StringFormat=Stored credentials: {0}}" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding SelectedAsset.ParseWarnings.Count, StringFormat=Parse warnings: {0}}" Margin="0,0,0,14" />

                            <TextBlock Text="Remote Access" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBox Text="{Binding SelectedAsset.WinRmCommand}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     Margin="0,0,0,6" />
                            <Button Content="Copy WinRM Command"
                                    HorizontalAlignment="Left"
                                    Command="{Binding CopyTextCommand}"
                                    CommandParameter="{Binding SelectedAsset.WinRmCommand}" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Text="{Binding LoadedCount, StringFormat=Loaded: {0}}" Margin="0,0,16,0" />
                <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Text="{Binding FilteredCount, StringFormat=Filtered: {0}}" Margin="0,0,16,0" />
                <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Text="{Binding OnlineCount, StringFormat=Online: {0}}" Margin="0,0,16,0" />
                <TextBlock Grid.Column="3" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Text="{Binding OfflineCount, StringFormat=Offline: {0}}" Margin="0,0,16,0" />
                <TextBlock Grid.Column="4" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Text="{Binding ErrorsCount, StringFormat=Warnings: {0}}" />
                <TextBlock Grid.Column="6" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Text="{Binding StatusMessage}" />
            </Grid>
        </Border>
    </Grid>
</Window>
